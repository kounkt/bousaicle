{
  "name": "bousaicle",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run build && touch dist/.nojekyll && cd dist && git init -b gh-pages && git add -A && git commit -m deploy && git push -f https://github.com/kounkt/bousaicle.git gh-pages && cd .. && rm -rf dist/.git"
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.6"
  }
}
